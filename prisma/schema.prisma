generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
  engineType    = "library"
}

datasource db {
  provider = "mysql"
}

model User {
  user_id         String          @id @default(uuid()) @db.Char(100)
  email           String          @unique @db.VarChar(50)
  password        String          @db.VarChar(255)
  name            String          @db.VarChar(50)
  surname         String          @db.VarChar(50)
  phone           String          @db.VarChar(20)
  address         String          @db.VarChar(255)
  city            String          @db.VarChar(50)
  country         String          @db.VarChar(50)
  postal_code     String          @db.VarChar(20)
  gender          String          @db.VarChar(10)
  birth_date      DateTime        @db.Date
  role            Role            @default(CLIENT)
  status          UserStatus      @default(ON)
  avatar          String          @db.VarChar(255)
  document_type   DocumentType    @default(DNI)
  document_number String          @db.VarChar(20)
  annotations     String?         @db.Text
  refresh_token   String?         @db.Text
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  client_bookings Booking[]       @relation("ClientBookings")
  staff_bookings  Booking[]       @relation("StaffBookings")
  carts           Cart[]
  consents        Consent[]
  debts           Debt[]
  questionnaires  Questionnaire[]
  revokes         Revoke[]

  @@index([role])
  @@index([status])
  @@index([created_at])
  @@map("users")
}

model Consent {
  consent_id   String       @id @default(uuid()) @db.Char(100)
  user_id      String?      @db.Char(100)
  consent_type ConsentType?
  status       String       @default("UNSIGNED") @db.VarChar(20)
  signed_date  DateTime     @default(now())
  document_url String?      @db.VarChar(255)
  notes        String?      @db.VarChar(255)
  created_at   DateTime?    @default(now())
  updated_at   DateTime?    @updatedAt
  user         User?        @relation(fields: [user_id], references: [user_id])

  @@unique([user_id, consent_type], name: "unique_user_consent")
  @@map("consents")
}

model Questionnaire {
  questionnaire_id String   @id @default(uuid()) @db.Char(100)
  user_id          String   @db.Char(100)
  title            String   @db.VarChar(150)
  data             String   @db.LongText
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  user             User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id], map: "questionnaires_user_id_fkey")
  @@map("questionnaires")
}

model Revoke {
  revoke_id    String   @id @default(uuid()) @db.Char(100)
  user_id      String   @db.Char(100)
  reason       String?  @db.Text
  date_revoked DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  user         User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id], map: "revokes_user_id_fkey")
  @@map("revokes")
}

model Product {
  product_id     String            @id @default(uuid()) @db.Char(100)
  name           String            @db.VarChar(150)
  description    String?           @db.Text
  sku            String?           @unique @db.VarChar(50)
  barcode        String?           @unique @db.VarChar(50)
  price          Float
  tax_rate       Float             @default(21)
  stock          Int               @default(0)
  min_stock      Int               @default(0)
  image_url      String?           @db.VarChar(255)
  status         String            @default("activo") @db.VarChar(20)
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  packItems      PackItemProduct[]

  @@index([status])
  @@map("products")
}

model Service {
  service_id  String            @id @default(uuid()) @db.Char(100)
  name        String            @db.VarChar(150)
  description String?           @db.Text
  code        String?           @unique @db.VarChar(50)
  price       Float
  tax_rate    Float             @default(21)
  duration    Int               @default(30)
  status      String            @default("activo") @db.VarChar(20)
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  bonuses     Bonus[]
  packItems   PackItemService[]

  @@map("services")
}

model Pack {
  pack_id     String            @id @default(uuid()) @db.Char(100)
  name        String            @db.VarChar(150)
  description String?           @db.Text
  code        String?           @unique @db.VarChar(50)
  price       Float
  tax_rate    Float             @default(21)
  status      String            @default("activo") @db.VarChar(20)
  image_url   String?           @db.VarChar(255)
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  products    PackItemProduct[]
  services    PackItemService[]

  @@map("packs")
}

model PackItemProduct {
  pack_id    String  @db.Char(100)
  product_id String  @db.Char(100)
  quantity   Int     @default(1)
  pack       Pack    @relation(fields: [pack_id], references: [pack_id], onDelete: Cascade)
  product    Product @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@id([pack_id, product_id])
  @@index([product_id], map: "pack_item_products_product_id_fkey")
  @@map("pack_item_products")
}

model PackItemService {
  pack_id    String  @db.Char(100)
  service_id String  @db.Char(100)
  quantity   Int     @default(1)
  pack       Pack    @relation(fields: [pack_id], references: [pack_id], onDelete: Cascade)
  service    Service @relation(fields: [service_id], references: [service_id], onDelete: Cascade)

  @@id([pack_id, service_id])
  @@index([service_id], map: "pack_item_services_service_id_fkey")
  @@map("pack_item_services")
}

model Coupon {
  coupon_id      String    @id @default(uuid()) @db.Char(100)
  code           String    @unique @db.VarChar(50)
  description    String?   @db.Text
  discount_type  String    @db.VarChar(50)
  discount_value Float
  min_purchase   Float?
  max_uses       Int?
  current_uses   Int       @default(0)
  valid_from     DateTime?
  valid_until    DateTime?
  status         String    @default("activo") @db.VarChar(20)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@map("coupons")
}

model Bonus {
  bonus_id       String        @id @default(uuid()) @db.Char(100)
  name           String        @db.VarChar(150)
  description    String?       @db.Text
  total_sessions Int
  price          Float
  status         String        @default("activo") @db.VarChar(20)
  service_id     String?       @db.Char(100)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  service        Service?      @relation(fields: [service_id], references: [service_id])
  client_bonuses ClientBonus[]

  @@index([service_id], map: "bonuses_service_id_fkey")
  @@map("bonuses")
}

model ClientBonus {
  client_bonus_id    String    @id @default(uuid()) @db.Char(100)
  client_id          String    @db.Char(100)
  bonus_id           String    @db.Char(100)
  remaining_sessions Int
  purchase_date      DateTime  @default(now())
  expiration_date    DateTime?
  status             String    @default("activo") @db.VarChar(20)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  bonus              Bonus     @relation(fields: [bonus_id], references: [bonus_id], onDelete: NoAction)

  @@index([bonus_id], map: "client_bonuses_bonus_id_fkey")
  @@map("client_bonuses")
}

model Giftcard {
  giftcard_id     String    @id @default(uuid()) @db.Char(100)
  code            String    @unique @db.VarChar(50)
  initial_balance Float
  current_balance Float
  issue_date      DateTime  @default(now())
  expiration_date DateTime?
  status          String    @default("active") @db.VarChar(20)
  client_id       String?   @db.Char(100)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@map("giftcards")
}

model Sequence {
  id         String   @id @default(uuid())
  type       String   @unique
  prefix     String
  year       Int
  last_value Int      @default(0)
  updated_at DateTime @updatedAt

  @@map("sequences")
}

model Cart {
  cart_id                  String     @id @default(uuid()) @db.Char(100)
  user_id                  String?    @db.Char(100)
  status                   String     @default("pending") @db.VarChar(20)
  subtotal                 Float      @default(0)
  discount                 Float      @default(0)
  total                    Float      @default(0)
  payment_method           String?    @db.VarChar(50)
  notes                    String?    @db.Text
  applied_coupon           String?    @db.VarChar(50)
  applied_giftcard         String?    @db.VarChar(50)
  invoice_number           String?    @unique @db.VarChar(50)
  invoice_type             String?    @db.VarChar(4)
  qr_content               String?    @db.Text
  aeat_status              String     @default("pending_submission") @db.VarChar(50)
  hash                     String?    @db.VarChar(100)
  previous_hash            String?    @db.VarChar(100)
  created_at               DateTime   @default(now())
  updated_at               DateTime   @updatedAt
  items                    CartItem[]
  user                     User?      @relation(fields: [user_id], references: [user_id])
  debts                    Debt[]

  @@index([user_id])
  @@index([status])
  @@index([created_at])
  @@map("carts")
}

model CartItem {
  cart_item_id String   @id @default(uuid()) @db.Char(100)
  cart_id      String   @db.Char(100)
  item_type    String   @db.VarChar(50)
  item_id      String   @db.Char(100)
  name         String   @db.VarChar(150)
  quantity     Int      @default(1)
  unit_price   Float
  tax_rate     Float    @default(21)
  subtotal     Float
  total        Float
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  cart         Cart     @relation(fields: [cart_id], references: [cart_id], onDelete: Cascade)

  @@index([cart_id], map: "cart_items_cart_id_fkey")
  @@map("cart_items")
}

model Debt {
  debt_id    String        @id @default(uuid()) @db.Char(100)
  user_id    String        @db.Char(100)
  cart_id    String?       @db.Char(100)
  amount     Float
  remaining  Float
  status     String        @default("pending") @db.VarChar(20)
  due_date   DateTime?
  notes      String?       @db.Text
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
  payments   DebtPayment[]
  cart       Cart?         @relation(fields: [cart_id], references: [cart_id])
  user       User          @relation(fields: [user_id], references: [user_id], onDelete: NoAction)

  @@index([user_id])
  @@index([status])
  @@index([created_at])
  @@index([cart_id], map: "debts_cart_id_fkey")
  @@map("debts")
}

model DebtPayment {
  payment_id     String   @id @default(uuid()) @db.Char(100)
  debt_id        String   @db.Char(100)
  amount         Float
  payment_method String   @db.VarChar(50)
  payment_date   DateTime @default(now())
  notes          String?  @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  debt           Debt     @relation(fields: [debt_id], references: [debt_id], onDelete: Cascade)

  @@index([debt_id], map: "debt_payments_debt_id_fkey")
  @@map("debt_payments")
}

model Booking {
  booking_id    String        @id @default(uuid()) @db.Char(100)
  client_id     String        @db.Char(100)
  staff_id      String?       @db.Char(100)
  item_type     String        @db.VarChar(50)
  item_id       String        @db.Char(100)
  status        String        @default("pending") @db.VarChar(20)
  booking_date  DateTime
  start_time    String        @db.VarChar(10)
  end_time      String        @db.VarChar(10)
  duration      Int
  notes         String?       @db.Text
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  booking_items BookingItem[]
  client        User          @relation("ClientBookings", fields: [client_id], references: [user_id], onDelete: NoAction)
  staff         User?         @relation("StaffBookings", fields: [staff_id], references: [user_id])

  @@index([client_id])
  @@index([staff_id])
  @@index([booking_date])
  @@index([status])
  @@map("bookings")
}

model BookingItem {
  booking_item_id String   @id @default(uuid()) @db.Char(100)
  booking_id      String   @db.Char(100)
  item_type       String   @db.VarChar(50)
  item_id         String   @db.Char(100)
  name            String   @db.VarChar(150)
  duration        Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt
  booking         Booking  @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade)

  @@index([booking_id], map: "booking_items_booking_id_fkey")
  @@map("booking_items")
}

enum Role {
  ADMIN
  STAFF
  CLIENT
}

enum UserStatus {
  ON
  OFF
}

enum ConsentType {
  LGPD
  INDIBA
  LASER_INNOVA_PRO_SHR
}

enum DocumentType {
  DNI
  PASSPORT
  NIE
}
