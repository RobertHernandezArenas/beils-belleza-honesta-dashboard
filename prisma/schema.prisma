model Consent {
  consentId              String              @id @default(uuid()) @db.Char(100)
  user_id                String?             @db.Char(100)
  consent_type           ConsentType?    
  accepted               Boolean?            @default(true)
  accepted_at            DateTime?           @db.DateTime
  document_url           String?             @db.VarChar(255)
  notes                  String?             @db.VarChar(255)
  created_at             DateTime?           @default(now())
  updated_at             DateTime?           @updatedAt

  user                 User?             @relation(fields: [user_id], references: [user_id])

  @@unique([user_id, consent_type], name: "unique_user_consent")
  @@map("consents")
}


model Questionnaire {
  questionnaire_id String   @id @default(uuid()) @db.Char(100)
  
  user_id          String   @db.Char(100)
  user             User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  
  title            String   @db.VarChar(150)
  data             Json     // Store arbitrary form data schema
  
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("questionnaires")
}

model Revoke {
  revoke_id       String   @id @default(uuid()) @db.Char(100)
  
  user_id         String   @db.Char(100)
  user            User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  
  reason          String?  @db.Text
  date_revoked    DateTime @default(now())
  
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("revokes")
}

// ==========================================
// PHASE 2: CATALOG (PRODUCTS)
// ==========================================

model Category {
  category_id   String        @id @default(uuid()) @db.Char(100)
  name          String        @unique @db.VarChar(100)
  description   String?       @db.Text
  subcategories Subcategory[]
  products      Product[]
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  @@map("categories")
}

model Subcategory {
  subcategory_id String   @id @default(uuid()) @db.Char(100)
  name           String   @db.VarChar(100)
  description    String?  @db.Text
  
  category_id    String   @db.Char(100)
  category       Category @relation(fields: [category_id], references: [category_id], onDelete: Cascade)
  
  products       Product[]
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@unique([name, category_id])
  @@map("subcategories")
}

model Tag {
  tag_id      String       @id @default(uuid()) @db.Char(100)
  name        String       @unique @db.VarChar(50)
  products    ProductTag[]
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  @@map("tags")
}

model Product {
  product_id     String       @id @default(uuid()) @db.Char(100)
  name           String       @db.VarChar(150)
  description    String?      @db.Text
  sku            String?      @unique @db.VarChar(50)
  barcode        String?      @unique @db.VarChar(50)
  price          Float        @db.Double
  tax_rate       Float        @default(21.0) @db.Double
  stock          Int          @default(0)
  min_stock      Int          @default(0)
  image_url      String?      @db.VarChar(255)
  status         String       @default("activo") @db.VarChar(20)

  category_id    String?      @db.Char(100)
  category       Category?    @relation(fields: [category_id], references: [category_id])
  
  subcategory_id String?      @db.Char(100)
  subcategory    Subcategory? @relation(fields: [subcategory_id], references: [subcategory_id])

  tags           ProductTag[]
  packItems      PackItemProduct[]
  
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  @@map("products")
}

model ProductTag {
  product_id String  @db.Char(100)
  product    Product @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  tag_id     String  @db.Char(100)
  tag        Tag     @relation(fields: [tag_id], references: [tag_id], onDelete: Cascade)

  @@id([product_id, tag_id])
  @@map("product_tags")
}

// ==========================================
// PHASE 3: SERVICES & PACKS
// ==========================================

model Service {
  service_id  String   @id @default(uuid()) @db.Char(100)
  name        String   @db.VarChar(150)
  description String?  @db.Text
  code        String?  @unique @db.VarChar(50)
  price       Float    @db.Double
  tax_rate    Float    @default(21.0) @db.Double
  duration    Int      @default(30) // Minutes
  status      String   @default("activo") @db.VarChar(20)
  
  packItems   PackItemService[]
  bonuses     Bonus[]

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("services")
}

model Pack {
  pack_id     String   @id @default(uuid()) @db.Char(100)
  name        String   @db.VarChar(150)
  description String?  @db.Text
  code        String?  @unique @db.VarChar(50)
  price       Float    @db.Double // Final combined price
  tax_rate    Float    @default(21.0) @db.Double
  status      String   @default("activo") @db.VarChar(20)
  image_url   String?  @db.VarChar(255)
  
  products    PackItemProduct[]
  services    PackItemService[]

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("packs")
}

model PackItemProduct {
  pack_id    String  @db.Char(100)
  pack       Pack    @relation(fields: [pack_id], references: [pack_id], onDelete: Cascade)
  
  product_id String  @db.Char(100)
  product    Product @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  
  quantity   Int     @default(1)

  @@id([pack_id, product_id])
  @@map("pack_item_products")
}

model PackItemService {
  pack_id    String  @db.Char(100)
  pack       Pack    @relation(fields: [pack_id], references: [pack_id], onDelete: Cascade)
  
  service_id String  @db.Char(100)
  service    Service @relation(fields: [service_id], references: [service_id], onDelete: Cascade)
  
  quantity   Int     @default(1)

  @@id([pack_id, service_id])
  @@map("pack_item_services")
}

// ==========================================
// PHASE 4: MARKETING & LOYALTY
// ==========================================

model Coupon {
  coupon_id          String   @id @default(uuid()) @db.Char(100)
  code               String   @unique @db.VarChar(50)
  description        String?  @db.Text
  discount_type      String   @db.VarChar(50) // 'percentage' or 'fixed'
  discount_value     Float    @db.Double
  min_purchase       Float?   @db.Double
  max_uses           Int?     
  current_uses       Int      @default(0)
  valid_from         DateTime?
  valid_until        DateTime?
  status             String   @default("activo") @db.VarChar(20)

  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@map("coupons")
}

model Bonus {
  bonus_id        String   @id @default(uuid()) @db.Char(100)
  name            String   @db.VarChar(150)
  description     String?  @db.Text
  total_sessions  Int      
  price           Float    @db.Double
  status          String   @default("activo") @db.VarChar(20)
  
  service_id      String?  @db.Char(100)
  service         Service? @relation(fields: [service_id], references: [service_id])

  client_bonuses  ClientBonus[]

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("bonuses")
}

model ClientBonus {
  client_bonus_id    String   @id @default(uuid()) @db.Char(100)
  
  // Later we can relate this directly to Client model when Phase 1 models are added/fixed if needed
  // For now we use a generic string to store client ID reference
  client_id          String   @db.Char(100) 
  
  bonus_id           String   @db.Char(100)
  bonus              Bonus    @relation(fields: [bonus_id], references: [bonus_id])
  
  remaining_sessions Int
  purchase_date      DateTime @default(now())
  expiration_date    DateTime?
  status             String   @default("activo") @db.VarChar(20)

  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@map("client_bonuses")
}

model Giftcard {
  giftcard_id        String   @id @default(uuid()) @db.Char(100)
  code               String   @unique @db.VarChar(50)
  initial_balance    Float    @db.Double
  current_balance    Float    @db.Double
  issue_date         DateTime @default(now())
  expiration_date    DateTime?
  status             String   @default("active") @db.VarChar(20) // active, used, expired
  
  // Optional reference to client who purchased or received it
  client_id          String?  @db.Char(100)

  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@map("giftcards")
}

// ==========================================
// VERI*FACTU & SEQUENCES
// ==========================================

model Sequence {
  id         String   @id @default(uuid())
  type       String   @unique // Ej: "invoice_2025"
  prefix     String   // Ej: "BBH"
  year       Int      // Ej: 2025
  last_value Int      @default(0)
  
  updated_at DateTime @updatedAt
  
  @@map("sequences")
}

// ==========================================
// PHASE 5: SALES / PAYMENTS / TPV (Point of Sale)
// ==========================================

model Cart {
  cart_id      String       @id @default(uuid()) @db.Char(100)
  
  user_id      String?      @db.Char(100)
  user         User?        @relation(fields: [user_id], references: [user_id])
  
  status       String       @default("pending") @db.VarChar(20) // pending, completed, cancelled
  subtotal     Float        @default(0) @db.Double
  discount     Float        @default(0) @db.Double
  total        Float        @default(0) @db.Double
  
  payment_method String?    @db.VarChar(50) // cash, card, transfer, mixed
  notes        String?      @db.Text
  
  // Applied coupons/giftcards during checkout (stored as codes for history)
  applied_coupon   String?  @db.VarChar(50)
  applied_giftcard String?  @db.VarChar(50)

  // Veri*Factu (AEAT) Fields
  invoice_number   String?  @unique @db.VarChar(50) // e.g. BBH-2025-001
  invoice_type     String?  @db.VarChar(4) // F1 (Factura Completa), F2 (Ticket)
  qr_content       String?  @db.Text
  aeat_status      String   @default("pending_submission") @db.VarChar(50) // pending_submission, submitted, error
  hash             String?  @db.VarChar(100)
  previous_hash    String?  @db.VarChar(100)

  // Stripe — Pago Fraccionado / Cuotas
  stripe_payment_intent_id  String?  @db.VarChar(255)
  stripe_installments       Int?     // 1, 3, 4, 6
  stripe_status             String?  @db.VarChar(50) // requires_payment_method, succeeded, failed

  items        CartItem[]
  debts        Debt[]
  
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt

  @@map("carts")
}

model CartItem {
  cart_item_id String   @id @default(uuid()) @db.Char(100)
  
  cart_id      String   @db.Char(100)
  cart         Cart     @relation(fields: [cart_id], references: [cart_id], onDelete: Cascade)
  
  item_type    String   @db.VarChar(50) // 'product', 'service', 'pack', 'bonus', 'giftcard'
  item_id      String   @db.Char(100) // The ID of the item being sold
  name         String   @db.VarChar(150) // Snapshot of name at time of sale
  
  quantity     Int      @default(1)
  unit_price   Float    @db.Double // Configured or overridden price
  tax_rate     Float    @default(21.0) @db.Double
  subtotal     Float    @db.Double // q * p
  total        Float    @db.Double // subtotal + tax
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("cart_items")
}

model Debt {
  debt_id         String   @id @default(uuid()) @db.Char(100)
  
  user_id         String   @db.Char(100)
  user            User     @relation(fields: [user_id], references: [user_id])
  
  cart_id         String?  @db.Char(100)
  cart            Cart?    @relation(fields: [cart_id], references: [cart_id], onDelete: SetNull)
  
  amount          Float    @db.Double
  remaining       Float    @db.Double
  status          String   @default("pending") @db.VarChar(20) // pending, partial, paid
  due_date        DateTime?
  notes           String?  @db.Text
  
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("debts")
}

// ==========================================
// PHASE 6: AGENDA / APPOINTMENTS (Bookings)
// ==========================================

model Booking {
  booking_id    String    @id @default(uuid()) @db.Char(100)
  
  // The client who booked
  client_id     String    @db.Char(100)
  client        User      @relation("ClientBookings", fields: [client_id], references: [user_id])
  
  // The staff member assigned to the booking
  staff_id      String?   @db.Char(100)
  staff         User?     @relation("StaffBookings", fields: [staff_id], references: [user_id])
  
  // Service or Pack booked
  item_type     String    @db.VarChar(50) // 'service', 'pack'
  item_id       String    @db.Char(100)
  
  status        String    @default("pending") @db.VarChar(20) // pending, confirmed, completed, cancelled, no_show
  
  booking_date  DateTime
  start_time    String    @db.VarChar(10) // HH:mm
  end_time      String    @db.VarChar(10) // HH:mm
  duration      Int       // stored in minutes for easy calculation
  
  notes         String?   @db.Text
  
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@map("bookings")
}
