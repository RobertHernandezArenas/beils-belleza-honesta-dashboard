generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  CLIENT
}

enum UserStatus {
  ON
  OFF
}

enum ConsentType {
  LGPD
  INDIBA
  LASER_INNOVA_PRO_SHR
}

enum DocumentType {
  DNI
  PASSPORT
  NIE
}

model User {
  user_id                  String               @id @default(uuid()) @db.Char(100)
  email                    String               @unique @db.VarChar(50)
  password                 String               @db.VarChar(255)
  name                     String               @db.VarChar(50)
  surname                  String               @db.VarChar(50)
  phone                    String               @db.VarChar(20)
  address                  String               @db.VarChar(255)
  city                     String               @db.VarChar(50)
  country                  String               @db.VarChar(50)
  postal_code              String               @db.VarChar(20)
  gender                   String               @db.VarChar(10)
  birth_date               DateTime             @db.Date
  role                     Role                 @default(CLIENT)
  status                   UserStatus           @default(ON)
  avatar                   String               @db.VarChar(255)
  document_type            DocumentType         @default(DNI)
  document_number          String               @db.VarChar(20)
  refresh_token            String?              @db.Text
  
  carts                    Cart[]
  debts                    Debt[]
  
  client_bookings          Booking[]            @relation("ClientBookings")
  staff_bookings           Booking[]            @relation("StaffBookings")
  
  consents                 Consent[]
  questionnaires           Questionnaire[]
  revokes                  Revoke[]

  created_at               DateTime             @default(now())
  updated_at               DateTime             @updatedAt

  @@map("users")
}

